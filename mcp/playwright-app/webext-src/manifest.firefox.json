{
  "manifest_version": 3,
  "name": "MyWant Web Inspector",
  "version": "1.0.0",
  "description": "Injects the MyWant Web Want Inspector overlay into the current page, bypassing page CSP via a content script.",
  "permissions": ["storage", "scripting", "activeTab", "tabs", "alarms"],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "MyWant Web Inspector"
  },
  "options_page": "options.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "webinspector@mywant.local"
    }
  }
}
